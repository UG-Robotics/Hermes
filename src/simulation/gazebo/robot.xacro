<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="hermes_bot">

  <!-- 1. CHASSIS -->
  <link name="base_footprint"/>
  <link name="base_link">
    <visual><geometry><box size="0.25 0.16 0.05"/></geometry><material name="blue"><color rgba="0 0 1 1"/></material></visual>
    <collision><geometry><box size="0.25 0.16 0.05"/></geometry></collision>
    <inertial><mass value="0.5"/><inertia ixx="0.002" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.006"/></inertial>
  </link>
  <joint name="base_joint" type="fixed"><parent link="base_footprint"/><child link="base_link"/><origin xyz="0 0 0.05" rpy="0 0 0"/></joint>

  <!-- 2. REAR DRIVE (N20 Motors) -->
  <link name="rear_left_wheel">
    <visual><geometry><cylinder radius="0.04" length="0.03"/></geometry><material name="black"><color rgba="0 0 0 1"/></material></visual>
    <collision><geometry><cylinder radius="0.04" length="0.03"/></geometry></collision>
    <inertial><mass value="0.1"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>
  <joint name="rear_left_joint" type="continuous"><parent link="base_link"/><child link="rear_left_wheel"/><origin xyz="-0.08 0.1 -0.01" rpy="1.5708 0 0"/><axis xyz="0 0 1"/></joint>

  <link name="rear_right_wheel">
    <visual><geometry><cylinder radius="0.04" length="0.03"/></geometry><material name="black"><color rgba="0 0 0 1"/></material></visual>
    <collision><geometry><cylinder radius="0.04" length="0.03"/></geometry></collision>
    <inertial><mass value="0.1"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>
  <joint name="rear_right_joint" type="continuous"><parent link="base_link"/><child link="rear_right_wheel"/><origin xyz="-0.08 -0.1 -0.01" rpy="1.5708 0 0"/><axis xyz="0 0 1"/></joint>

  <!-- 3. FRONT STEERING (Ackermann/Servo) -->
  <link name="front_left_steer_hinge">
    <visual><geometry><sphere radius="0.015"/></geometry><material name="red"><color rgba="1 0 0 1"/></material></visual>
    <inertial><mass value="0.05"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>
  <joint name="front_left_steer_joint" type="revolute"><parent link="base_link"/><child link="front_left_steer_hinge"/><origin xyz="0.1 0.08 -0.01"/><axis xyz="0 0 1"/><limit lower="-0.5" upper="0.5" effort="10" velocity="1.0"/></joint>

  <link name="front_left_wheel">
    <visual><geometry><cylinder radius="0.04" length="0.03"/></geometry><material name="black"><color rgba="0 0 0 1"/></material></visual>
    <collision><geometry><cylinder radius="0.04" length="0.03"/></geometry></collision>
    <inertial><mass value="0.1"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>
  <joint name="front_left_wheel_joint" type="continuous"><parent link="front_left_steer_hinge"/><child link="front_left_wheel"/><origin xyz="0 0.02 0" rpy="1.5708 0 0"/><axis xyz="0 0 1"/></joint>

  <link name="front_right_steer_hinge">
    <visual><geometry><sphere radius="0.015"/></geometry><material name="red"><color rgba="1 0 0 1"/></material></visual>
    <inertial><mass value="0.05"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>
  <joint name="front_right_steer_joint" type="revolute"><parent link="base_link"/><child link="front_right_steer_hinge"/><origin xyz="0.1 -0.08 -0.01"/><axis xyz="0 0 1"/><limit lower="-0.5" upper="0.5" effort="10" velocity="1.0"/></joint>

  <link name="front_right_wheel">
    <visual><geometry><cylinder radius="0.04" length="0.03"/></geometry><material name="black"><color rgba="0 0 0 1"/></material></visual>
    <collision><geometry><cylinder radius="0.04" length="0.03"/></geometry></collision>
    <inertial><mass value="0.1"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>
  <joint name="front_right_wheel_joint" type="continuous"><parent link="front_right_steer_hinge"/><child link="front_right_wheel"/><origin xyz="0 -0.02 0" rpy="1.5708 0 0"/><axis xyz="0 0 1"/></joint>

  <!-- 4. NAVIGATION SENSORS -->
  <link name="tof_front"><visual><geometry><box size="0.02 0.02 0.01"/></geometry><material name="green"><color rgba="0 1 0 1"/></material></visual></link>
  <joint name="tof_front_j" type="fixed"><parent link="base_link"/><child link="tof_front"/><origin xyz="0.125 0 0.02"/></joint>

  <link name="tof_left"><visual><geometry><box size="0.02 0.02 0.01"/></geometry><material name="green"/></visual></link>
  <joint name="tof_left_j" type="fixed"><parent link="base_link"/><child link="tof_left"/><origin xyz="0.05 0.08 0.02" rpy="0 0 1.5708"/></joint>

  <link name="tof_right"><visual><geometry><box size="0.02 0.02 0.01"/></geometry><material name="green"/></visual></link>
  <joint name="tof_right_j" type="fixed"><parent link="base_link"/><child link="tof_right"/><origin xyz="0.05 -0.08 0.02" rpy="0 0 -1.5708"/></joint>

  <link name="camera_link"><visual><geometry><box size="0.02 0.03 0.03"/></geometry><material name="yellow"><color rgba="1 1 0 1"/></material></visual></link>
  <joint name="camera_j" type="fixed"><parent link="base_link"/><child link="camera_link"/><origin xyz="0.12 0 0.04"/></joint>

  <link name="imu_link"><visual><geometry><box size="0.03 0.03 0.005"/></geometry><material name="purple"><color rgba="0.5 0 0.5 1"/></material></visual></link>
  <joint name="imu_j" type="fixed"><parent link="base_link"/><child link="imu_link"/><origin xyz="0 0 0.025"/></joint>

  <!-- 5. COMPUTING & POWER -->
  <link name="pi_link"><visual><geometry><box size="0.085 0.056 0.02"/></geometry><material name="grey"><color rgba="0.4 0.4 0.4 1"/></material></visual></link>
  <joint name="pi_j" type="fixed"><parent link="base_link"/><child link="pi_link"/><origin xyz="0.02 0 0.045"/></joint>

  <link name="power_block"><visual><geometry><box size="0.12 0.08 0.04"/></geometry><material name="grey"/></visual><inertial><mass value="0.4"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial></link>
  <joint name="power_j" type="fixed"><parent link="base_link"/><child link="power_block"/><origin xyz="-0.06 0 0.035"/></joint>

  <!-- ═══════════════════════════════════════════════════════════════════════
       6. GAZEBO PLUGINS
       ───────────────────────────────────────────────────────────────────────
       World-level systems block.
         • AckermannSteering  – drives wheels from /cmd_vel
         • Imu                – world system that enables IMU sensor instances
         • Sensors            – REQUIRED for gpu_lidar (ToF) to render
       ═══════════════════════════════════════════════════════════════════════ -->
  <gazebo>
    <plugin filename="gz-sim-ackermann-steering-system" name="gz::sim::systems::AckermannSteering">
      <left_joint>rear_left_joint</left_joint>
      <right_joint>rear_right_joint</right_joint>
      <left_steering_joint>front_left_steer_joint</left_steering_joint>
      <right_steering_joint>front_right_steer_joint</right_steering_joint>
      <kingpin_width>0.16</kingpin_width>
      <wheelbase>0.18</wheelbase>
      <wheel_radius>0.04</wheel_radius>
      <topic>/cmd_vel</topic>
    </plugin>

    <!-- Imu world system-->
    <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu"/>

    <!-- Sensors world system-->
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════════════════════════
       7. SENSOR DEFINITIONS
       ───────────────────────────────────────────────────────────────────────
       VL53L1X ToF → gpu_lidar, 5 rays
       MPU-6050 IMU → imu sensor
       ═══════════════════════════════════════════════════════════════════════ -->

  <!-- Front ToF -->
  <gazebo reference="tof_front">
    <sensor name="tof_front_sensor" type="gpu_lidar">
      <always_on>1</always_on>
      <update_rate>20</update_rate>
      <topic>/tof_front</topic>
      <gz_frame_id>tof_front</gz_frame_id>
      <visualize>false</visualize>
      <lidar>
        <scan>
          <horizontal>
            <samples>5</samples>
            <resolution>1</resolution>
            <min_angle>-0.0873</min_angle>
            <max_angle> 0.0873</max_angle>
          </horizontal>
          <vertical>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.04</min>
          <max>4.00</max>
          <resolution>0.001</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.003</stddev>
        </noise>
      </lidar>
    </sensor>
  </gazebo>

  <!-- Left ToF -->
  <gazebo reference="tof_left">
    <sensor name="tof_left_sensor" type="gpu_lidar">
      <always_on>1</always_on>
      <update_rate>20</update_rate>
      <topic>/tof_left</topic>
      <gz_frame_id>tof_left</gz_frame_id>
      <visualize>false</visualize>
      <lidar>
        <scan>
          <horizontal>
            <samples>5</samples>
            <resolution>1</resolution>
            <min_angle>-0.0873</min_angle>
            <max_angle> 0.0873</max_angle>
          </horizontal>
          <vertical>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.04</min>
          <max>4.00</max>
          <resolution>0.001</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.003</stddev>
        </noise>
      </lidar>
    </sensor>
  </gazebo>

  <!-- Right ToF -->
  <gazebo reference="tof_right">
    <sensor name="tof_right_sensor" type="gpu_lidar">
      <always_on>1</always_on>
      <update_rate>20</update_rate>
      <topic>/tof_right</topic>
      <gz_frame_id>tof_right</gz_frame_id>
      <visualize>false</visualize>
      <lidar>
        <scan>
          <horizontal>
            <samples>5</samples>
            <resolution>1</resolution>
            <min_angle>-0.0873</min_angle>
            <max_angle> 0.0873</max_angle>
          </horizontal>
          <vertical>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.04</min>
          <max>4.00</max>
          <resolution>0.001</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.003</stddev>
        </noise>
      </lidar>
    </sensor>
  </gazebo>

  <!-- IMU (MPU-6050) -->
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>1</always_on>
      <update_rate>100</update_rate>
      <topic>/imu</topic>
      <gz_frame_id>imu_link</gz_frame_id>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.009</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.009</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.009</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.021</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.021</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.021</stddev></noise></z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>

</robot>
